{
  "manifest_version": 3,
  "name": "Judol Detector AyamMerdeka",
  "version": "1.0.0",
  "description": "Chromium extension for detecting online gambling content using pattern matching algorithms.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["keywords/keywords.txt"],
      "matches": ["<all_urls>"]
    }
  ]
}